---
import { socialLinks } from '../data/social-links'

const heroSocials = socialLinks
  .filter((l) => l.heroOrder <= 5)
  .sort((a, b) => a.heroOrder - b.heroOrder)
---

<div class="hero-panel-card">
  <!-- Avatar -->
  <div class="hero-panel-avatar">
    <div class="avatar-placeholder"></div>
  </div>

  <!-- Info -->
  <h2 class="hero-panel-name">赵佶</h2>
  <p class="hero-panel-tagline">宋徽宗 / 艺术家皇帝</p>

  <!-- Social -->
  <div class="hero-panel-socials">
    {heroSocials.map((link) => (
      <a
        href={link.url}
        target={link.url.startsWith('http') ? '_blank' : undefined}
        rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}
        aria-label={link.name}
        class="hero-social-icon"
      >
        <svg width="18" height="18" viewBox={link.viewBox} fill="currentColor">
          <path d={link.icon} />
        </svg>
      </a>
    ))}
  </div>

  <!-- Location -->
  <div class="hero-panel-location">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
      <circle cx="12" cy="10" r="3" />
    </svg>
    <span>中国</span>
  </div>
</div>

<style>
  .hero-panel-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 2rem 1.5rem;
    text-align: center;
    position: sticky;
    top: 80px;
  }

  .hero-panel-avatar {
    margin-bottom: 1rem;
  }

  .avatar-placeholder {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--color-bg-alt);
    border: 3px solid var(--color-border);
    margin: 0 auto;
  }

  .hero-panel-name {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    margin-bottom: 0.25rem;
  }

  .hero-panel-tagline {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .hero-panel-socials {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .hero-social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    color: var(--color-text-muted);
    transition: all 0.2s ease;
  }

  .hero-social-icon:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-2px);
  }

  .hero-panel-location {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 1023px) {
    .hero-panel-card {
      display: none;
    }
  }
</style>
