---
import { formatDate } from '../utils/date'
import type { CollectionEntry } from 'astro:content'

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/'

interface Props {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props
const { title, description, date, category } = post.data
---

<a href={`${base}posts/${post.id}`} class="post-card">
  <div class="post-card-meta">
    {category && <span class="tag">{category}</span>}
    {date && <span class="post-card-date">{formatDate(date)}</span>}
  </div>
  <h3 class="post-card-title">{title}</h3>
  {description && <p class="post-card-desc">{description}</p>}
</a>
