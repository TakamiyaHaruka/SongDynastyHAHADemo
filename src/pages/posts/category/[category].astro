---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import PostCard from '../../../components/PostCard.astro'
import PostSidebar from '../../../components/PostSidebar.astro'
import { getCollection } from 'astro:content'
import { sortPostsByDate } from '../../../utils/date'
import { getCategoryItems } from '../../../utils/categories'

export async function getStaticPaths() {
  const allPosts = await getCollection('blog')
  const posts = sortPostsByDate(allPosts)
  const categories = getCategoryItems(posts)

  return categories.map((cat) => ({
    params: { category: cat.name },
    props: {
      category: cat.name,
      posts: posts.filter((p) => (p.data.category ?? 'Uncategorized') === cat.name),
      allCategories: categories,
    },
  }))
}

const { category, posts, allCategories } = Astro.props
---

<BaseLayout title={`分类: ${category}`} currentPath={`/posts/category/${category}`}>
  <div class="container-main" style="padding-top: 3rem; padding-bottom: 3rem;">
    <div class="section-label">分类</div>
    <h1 class="section-heading">{category}</h1>
    <div class="accent-bar"></div>

    <div class="posts-layout">
      <div class="posts-list">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
      <div class="posts-aside">
        <PostSidebar categories={allCategories} activeCategory={category} />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .posts-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .posts-layout {
      grid-template-columns: 1fr 240px;
    }
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 0;
  }

  .posts-aside {
    display: none;
  }

  @media (min-width: 768px) {
    .posts-aside {
      display: block;
    }
  }
</style>
