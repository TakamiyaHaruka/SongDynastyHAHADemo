---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection, render } from 'astro:content'
import { formatDate } from '../../utils/date'

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { entry: post },
  }))
}

const { entry } = Astro.props
const { title, description, date, category, tags } = entry.data
const { Content } = await render(entry)

const ogImageUrl = new URL(`${base}og/${entry.id}.png`, Astro.site).toString()
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImageUrl}
  currentPath={`/posts/${entry.id}`}
>
  <article class="container-main" style="padding-top: 3rem; padding-bottom: 3rem;">
    <!-- Header -->
    <header class="post-header">
      <div class="post-meta">
        {category && <span class="tag">{category}</span>}
        {date && <span class="post-card-date">{formatDate(date)}</span>}
      </div>
      <h1 class="post-title">{title}</h1>
      {description && <p class="post-description">{description}</p>}
      {tags && tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <hr class="post-divider" />

    <!-- Content -->
    <div class="prose">
      <Content />
    </div>

    <!-- Back Link -->
    <div class="post-footer">
      <a href={`${base}posts`} class="btn-outline">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        返回文章列表
      </a>
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 2rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .post-description {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post-divider {
    border: none;
    height: 1px;
    background: var(--color-border);
    margin-bottom: 2rem;
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
</style>
