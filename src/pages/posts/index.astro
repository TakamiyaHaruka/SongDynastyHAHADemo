---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PostCard from '../../components/PostCard.astro'
import PostSidebar from '../../components/PostSidebar.astro'
import { getCollection } from 'astro:content'
import { sortPostsByDate } from '../../utils/date'
import { getCategoryItems } from '../../utils/categories'

const allPosts = await getCollection('blog')
const posts = sortPostsByDate(allPosts)
const categories = getCategoryItems(posts)
---

<BaseLayout title="文章" currentPath="/posts">
  <div class="container-main" style="padding-top: 3rem; padding-bottom: 3rem;">
    <div class="section-label">博客</div>
    <h1 class="section-heading">全部文章</h1>
    <div class="accent-bar"></div>

    <div class="posts-layout">
      <div class="posts-list">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
      <div class="posts-aside">
        <PostSidebar categories={categories} />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .posts-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .posts-layout {
      grid-template-columns: 1fr 240px;
    }
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 0;
  }

  .posts-aside {
    display: none;
  }

  @media (min-width: 768px) {
    .posts-aside {
      display: block;
    }
  }
</style>
